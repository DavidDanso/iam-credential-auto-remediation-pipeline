# =============================================================
# Terraform
# =============================================================

# Local state — contains resource IDs and may contain secrets
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan output — can contain sensitive values
*.tfplan

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Variable values — contains your email, region, project name
terraform.tfvars
*.auto.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json


# =============================================================
# AWS credentials
# =============================================================

# Never commit AWS credentials
.aws/
credentials
*.pem
*.key


# =============================================================
# Lambda build artifacts
# =============================================================

# ZIP packages generated by Terraform archive_file
*.zip

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/


# =============================================================
# OS and editor noise
# =============================================================

.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# =============================================================
response.json